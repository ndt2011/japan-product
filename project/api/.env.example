APP_NAME="Japan Product API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tokyo
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=japan_product_db
DB_USERNAME=root
DB_PASSWORD=

# Local dev fallback: DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# sync = local đơn giản (AI job chạy ngay) | database/redis = cần queue:work
QUEUE_CONNECTION=sync

SANCTUM_TOKEN_EXPIRATION=1440

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Railway staging: REDIS_URL=${{Redis.REDIS_URL}} (service product — không copy hết vars từ Redis service)
REDIS_CLIENT=phpredis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Fallback inbox đơn mới nếu admin không có email
MAIL_ORDER_NOTIFY_ADDRESS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Product images: public (local) | r2 (Cloudflare R2 staging/prod)
PRODUCT_IMAGE_DISK=public
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# --- AI Product Search (xem docs/sa/AI_Setup_Guide.md) ---
# Để TRỐNG OPENAI_API_KEY = tìm sản phẩm JP (luồng B) trả về rỗng; luồng A dùng embedding DB
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_SEARCH_LIMIT=15
AI_SEARCH_HYBRID_ENABLED=true

# --- Rakuten Ichiba (luồng A — ưu tiên trước OpenAI) ---
# Đăng ký: https://webservice.rakuten.co.jp/
RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=
# URL đã đăng ký trên Rakuten Developers (許可されたWebサイト) — thường http://localhost:3000 hoặc domain Vercel
RAKUTEN_ORIGIN_URL=http://localhost:3000

# Giá bán VND = cost_jpy × tỷ giá JPY/VND × (1 + markup%)
PRODUCT_MARKUP_PERCENT=30

VITE_APP_NAME="${APP_NAME}"
