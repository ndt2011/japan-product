# Railway — service Laravel API (project/api)
# Copy vào Railway → Variables → RAW Editor
# Thay THAY_* trước khi deploy

APP_NAME=JapanProductAPI
APP_ENV=staging
# Tạo trên MÁY LOCAL: php artisan key:generate --show (KHÔNG chạy trong Railway Shell)
APP_KEY=base64:THAY_BANG_OUTPUT_cua_php_artisan_key_generate_show
APP_DEBUG=false
APP_TIMEZONE=Asia/Tokyo
APP_URL=https://THAY-BANG-API-DOMAIN.up.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

# BẮT BUỘC — thiếu dòng này Laravel dùng sqlite → seed/login lỗi
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# Staging: sync queue + database cache (ít lỗi hơn khi mới deploy)
# Sau khi ổn định có thể đổi sang redis (cần REDIS_URL + ext-redis hoặc predis)
CACHE_STORE=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_CLIENT=phpredis

SANCTUM_TOKEN_EXPIRATION=1440
SANCTUM_STATEFUL_DOMAINS=japan-product.vercel.app

FILESYSTEM_DISK=local
PRODUCT_IMAGE_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@staging.local
MAIL_FROM_NAME=JapanProduct Staging

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_SEARCH_LIMIT=15

# --- Rakuten Ichiba (AI tìm sản phẩm — docs/devops/rakuten-api-setup.md) ---
# Copy giá trị từ project/api/.env local (không commit .env lên Git)
RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
# RAKUTEN_AFFILIATE_ID=
# Khớp domain Vercel đã đăng ký trên Rakuten Developers
RAKUTEN_ORIGIN_URL=https://japan-product.vercel.app

# Giá bán VND = cost_jpy × tỷ giá × (1 + markup%)
PRODUCT_MARKUP_PERCENT=30
